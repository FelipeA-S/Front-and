A parte do React:
import React from "https://esm.sh/react";
import ReactDOM from "https://esm.sh/react-dom";
import { StrictMode } from "https://esm.sh/react";
import { createRoot } from "https://esm.sh/react-dom/client";
import { useState } from;

const tamanho = 8;
const quantidadeNavios = 5;
let tabuleiro = [];
let tiros = 0;
let acertos = 0;

function iniciarJogo(){
    tiros = 0;
    acertos = 0;
    document.getElementById("tiros").textContent = tiros;
    document.getElementById("acertos").textContent = acertos;
    tabuleiro = [];
    for(let i=0;i<tamanho;i++){
        tabuleiro[i] = [];
        for(let j=0;j<tamanho;j++){
            tabuleiro[i][j] = {
                navio:false,
                clicado:false
            };
        }
    }
    let colocados = 0;
    while(colocados < quantidadeNavios){
        let linha = Math.floor(Math.random()*tamanho);
        let coluna = Math.floor(Math.random()*tamanho);
        if(!tabuleiro[linha][coluna].navio){
            tabuleiro[linha][coluna].navio = true;
            colocados++;
        }
    }
    desenharTabuleiro();
}

function desenharTabuleiro(){
    const area = document.getElementById("tabuleiro");
    area.innerHTML = "";
    for(let i=0;i<tamanho;i++){
        for(let j=0;j<tamanho;j++){
            const btn = document.createElement("button");
            btn.className = "celula";
            if(tabuleiro[i][j].clicado){
                if(tabuleiro[i][j].navio){
                    btn.classList.add("acerto");
                    btn.textContent = "🚢";
                }else{
                    btn.classList.add("erro");
                    btn.textContent = "💦";
                }
            }
            btn.onclick = () => atacar(i,j);
            area.appendChild(btn);
        }
    }
}

function atacar(i,j){
    if(tabuleiro[i][j].clicado){
        return;
    }
    tabuleiro[i][j].clicado = true;
    tiros++;
    if(tabuleiro[i][j].navio){
        acertos++;
    }
    document.getElementById("tiros").textContent = tiros;
    document.getElementById("acertos").textContent = acertos;
    desenharTabuleiro();
    if(acertos === quantidadeNavios){
        setTimeout(() => {
            alert("🎉 Você venceu!");
        },100);
    }
}

